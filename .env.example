# Auth0 v4
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# DeepSeek (used by normalizers — Phase 1 product, Phase 2 query)
DEEPSEEK_API_KEY=
# Optional model overrides (defaults: deepseek-v4-flash / deepseek-v4-pro)
# DEEPSEEK_MODEL_FLASH=
# DEEPSEEK_MODEL_PRO=
# DEEPSEEK_TIMEOUT_MS=60000

# Anthropic (optional — only used by healthcheck test gated with RUN_ANTHROPIC_HEALTH=1)
ANTHROPIC_API_KEY=

# Voyage
VOYAGE_API_KEY=

# Apify (real scraping providers — sector b-catalog/apify)
APIFY_TOKEN=
# Proveedor activo del agregador (default mock; apify-amazon|apify-aliexpress|apify-shein)
AGGREGATOR_PROVIDER=
# Fuentes para el cron de refresco diario (csv, default amazon)
APIFY_CRON_SOURCES=
# Tope diario de gasto del agregador en centavos (default 400)
AGGREGATOR_DAILY_BUDGET_CENTS=
# Fuentes del provider "multi" (csv de nombres del registry en provider.ts,
# default amazon-prod,aliexpress-prod). Fan-out en paralelo: cada búsqueda que
# dispara ingesta llama a TODAS las fuentes listadas, así que el gasto se
# multiplica por el número de fuentes. AGGREGATOR_DAILY_BUDGET_CENTS sigue
# siendo el freno global — suma todo mock_calls sin importar cuántas fuentes
# lo generaron.
MULTI_PROVIDER_SOURCES=

# E2E test user (NOT committed)
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=

# Búsqueda F4 — política de ingesta externa
# Piso de similitud coseno para contar un "hit fuerte" (dispara la ingesta externa
# cuando hay pocos). Un hit cuenta si vino de BM25 (match léxico) o si su score
# coseno >= este valor. Default 0.55. Poner 0 = todos los hits cuentan (política vieja).
# SEARCH_STRONG_HIT_MIN_SCORE=0.55

# Re-validación de precio/stock en checkout (ver sectors/b-catalog/revalidate.ts)
# Antigüedad máxima (horas) de last_refreshed_at antes de re-consultar el precio
# vivo al confirmar un pedido. Default 6.
# REVALIDATE_MAX_AGE_HOURS=6
# Kill-switch de /api/checkout/revalidate (default on; "false" → todos "unverifiable" sin llamadas)
# CHECKOUT_REVALIDATE=

# Hidratación de detalle bajo demanda de la PDP (variantes talla/color/precio/
# foto por SKU, ver sectors/b-catalog/hydrate.ts)
# Kill-switch de POST /api/products/[id]/hydrate (default on; "false" → siempre {skipped:true})
# HYDRATE_DETAIL=
# Tope mensual (comparte cuota con checkout_revalidate) de llamadas a AliExpress
# DataHub disparadas por hidratación. Default 40 (conservador frente al tope
# duro real de 100/mes del plan free-tier).
# HYDRATE_QUOTA_ALIEXPRESS=40

# Misc
# Set TEST_HEALTH_ENDPOINTS=1 (and run `pnpm dev` first) to include /api/health/* in test:integration
TEST_HEALTH_ENDPOINTS=
